# ── Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in the actual values.
# DO NOT commit .env.local to the repository.

# The base URL of your website (used for SEO and sitemap generation)
# Example: https://atlasconstructiongroup.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact Form Configuration
# The destination email address for lead submissions
CONTACT_EMAIL_DESTINATION=info@atlasconstruction.com

# Optional: If using a third-party email API (e.g., Resend, SendGrid)
# Provide the API Key below.
# EMAIL_API_KEY=your_api_key_here

# Optional: Google Analytics ID (if applicable)
NEXT_PUBLIC_GA_ID=